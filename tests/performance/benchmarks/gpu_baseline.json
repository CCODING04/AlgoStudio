{
  "version": "v1.0",
  "date": "2026-03-26",
  "description": "GPU performance baseline for AlgoStudio",
  "gpu_model": "NVIDIA RTX 4090",
  "targets": {
    "training": {
      "startup_time_s": 30,
      "gpu_utilization_percent": 80,
      "gpu_memory_used_gb": 20,
      "epoch_time_tolerance_percent": 10
    },
    "inference": {
      "batch_1_latency_p99_ms": 500,
      "batch_16_latency_p99_ms": 2000,
      "throughput_img_per_sec": 10,
      "model_load_time_s": 10
    },
    "scheduling": {
      "decision_latency_p95_ms": 100
    }
  },
  "thresholds": {
    "gpu_utilization_min_percent": 80,
    "gpu_utilization_max_percent": 95,
    "gpu_memory_min_gb": 18,
    "gpu_memory_max_gb": 22
  }
}
